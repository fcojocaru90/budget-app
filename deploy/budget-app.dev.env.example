# Copy to /data/docker/budget-app.dev.env on the home server (alyx) and fill in.
# This file holds the shared-Postgres credentials and dev host ports; it lives only
# on the server and is never committed. docker-compose.dev.yml interpolates it.

# Shared Postgres superuser (same as /data/docker/.env) — the dev app connects to
# the budget_dev database with these.
POSTGRES_USER=budget_admin
POSTGRES_PASSWORD=

# Host ports (bound to 192.168.1.3 / LAN) for the dev tier.
DEV_API_PORT=8000
DEV_FRONTEND_PORT=8080
