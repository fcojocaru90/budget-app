# Copy to .env.<tier> (.env.local, .env.dev, .env.staging, .env.production).
# The tier is selected via APP_ENV; variable names are identical across tiers.
APP_ENV=local
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/budget_local
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
OCR_STORAGE_PATH=./uploads/receipts
CORS_ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
